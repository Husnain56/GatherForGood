<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg_gradient"
    tools:context=".LoginScreen">

    <!-- Background Star Pattern -->
    <ImageView
        android:id="@+id/starPattern"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.19"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_star_pattern"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Bar -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="24dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="start"
                    android:background="@drawable/register_bg_input_field"
                    android:padding="8dp"
                    android:src="@drawable/register_ic_back_arrow"
                    app:tint="@color/soft_gold" />

                <TextView
                    android:id="@+id/tvAppTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:fontFamily="@font/playfair_display_italic"
                    android:gravity="center"
                    android:letterSpacing="0.3"
                    android:text="@string/app_name"
                    android:textColor="@color/gold_accent"
                    android:textSize="14sp"
                    android:textStyle="bold|italic" />

            </FrameLayout>

            <!-- Form Container -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/formContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:background="@drawable/register_bg_arch_container"
                android:paddingHorizontal="32dp"
                android:paddingTop="72dp"
                android:paddingBottom="48dp">

                <!-- Mosque Icon floats above form -->
                <FrameLayout
                    android:id="@+id/mosqueIconContainer"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginTop="-20dp"
                    android:background="@drawable/register_bg_arch_container"
                    android:elevation="4dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_mosque"
                        app:tint="@color/soft_gold" />
                </FrameLayout>

                <!-- Welcome Back -->
                <TextView
                    android:id="@+id/tvWelcomeBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/playfair_display_italic"
                    android:text="@string/user_welcome"
                    android:textColor="@color/soft_gold"
                    android:textSize="32sp"
                    android:layout_marginTop="50dp"
                    android:textStyle="bold|italic"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/mosqueIconContainer" />

                <TextView
                    android:id="@+id/tvJoinMsg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:letterSpacing="0.1"
                    android:text="@string/login_msg"
                    android:textColor="#99FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvWelcomeBack" />

                <!-- Email Label -->
                <TextView
                    android:id="@+id/lblEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="32dp"
                    android:letterSpacing="0.2"
                    android:text="@string/email_address"
                    android:textColor="#CCD4AF37"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvJoinMsg" />

                <!-- Email Input -->
                <LinearLayout
                    android:id="@+id/emailInputContainer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/register_bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    app:layout_constraintTop_toBottomOf="@id/lblEmail">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_email"
                        app:tint="#4DFFFFFF" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:background="@android:color/transparent"
                        android:hint="@string/email_hint"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/white"
                        android:textColorHint="#4DFFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Password Label Row -->
                <TextView
                    android:id="@+id/lblPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="24dp"
                    android:letterSpacing="0.2"
                    android:text="@string/password"
                    android:textColor="#CCD4AF37"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/emailInputContainer" />

                <TextView
                    android:id="@+id/tvForgot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="@string/forgot_pass"
                    android:textColor="@color/gold_accent"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/lblPassword"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/lblPassword" />

                <!-- Password Input -->
                <LinearLayout
                    android:id="@+id/passwordInputContainer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/register_bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    app:layout_constraintTop_toBottomOf="@id/lblPassword">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#4DFFFFFF" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@android:color/transparent"
                        android:hint="@string/pass_hint"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="#4DFFFFFF"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/ivPasswordVisibility"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.4"
                        android:src="@drawable/register_ic_visibility"
                        app:tint="@color/gold_accent" />

                </LinearLayout>

                <!-- Sign In Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="40dp"
                    android:background="@drawable/register_bg_gender_active"
                    android:fontFamily="@font/playfair_display_italic"
                    android:text="@string/sign_in_btn"
                    android:textAllCaps="true"
                    android:textColor="@color/deep_emerald"
                    android:textSize="18sp"
                    android:textStyle="bold|italic"
                    app:layout_constraintTop_toBottomOf="@id/passwordInputContainer" />

                <!-- Progress Bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminateTint="#D4AF37"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@id/btnSignIn"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/btnSignIn" />

                <!-- Register Link -->
                <LinearLayout
                    android:id="@+id/registerLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnSignIn">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_account_msg"
                        android:textColor="#80FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvJoinCommunity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/join_community"
                        android:textColor="@color/soft_gold"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Bottom Decorative Lattice -->
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginTop="32dp"
                    android:alpha="0.2"
                    android:src="@drawable/register_ic_lattice"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/registerLink"
                    app:tint="@color/gold_accent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Bottom Nav Placeholder -->
            <LinearLayout
                android:id="@+id/bottomNavPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="48dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="16dp"
                    android:src="@drawable/ic_home"
                    app:tint="#4DFFFFFF" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="16dp"
                    android:src="@drawable/ic_mosque"
                    app:tint="@color/gold_accent" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="16dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#4DFFFFFF" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="16dp"
                    android:src="@drawable/ic_profile"
                    app:tint="#4DFFFFFF" />
            </LinearLayout>

            <!-- Footer Text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="48dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="BY CONTINUING, YOU AGREE TO GATHERFORGOOD'S TERMS OF SERVICE AND PRIVACY POLICY."
                android:textColor="#4DFFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>