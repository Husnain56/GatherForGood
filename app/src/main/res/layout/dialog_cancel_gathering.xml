<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_cancel"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/playfair_display_bold"
        android:text="Cancel Gathering"
        android:textColor="#F9F1D7"
        android:textSize="22sp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:text="Why are you cancelling?"
        android:textColor="#80F9F1D7"
        android:textSize="13sp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="#1AFFFFFF" />

    <!-- Reason: Accidentally Created -->
    <RadioGroup
        android:id="@+id/rgReasons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <RadioButton
            android:id="@+id/rbAccidental"
            style="@style/CancelReasonRadio"
            android:text="Accidentally created" />

        <RadioButton
            android:id="@+id/rbChangePlans"
            style="@style/CancelReasonRadio"
            android:text="Change of plans" />

        <RadioButton
            android:id="@+id/rbVenue"
            style="@style/CancelReasonRadio"
            android:text="Venue not available" />

        <RadioButton
            android:id="@+id/rbParticipants"
            style="@style/CancelReasonRadio"
            android:text="Not enough participants" />

        <RadioButton
            android:id="@+id/rbEmergency"
            style="@style/CancelReasonRadio"
            android:text="Personal emergency" />

        <RadioButton
            android:id="@+id/rbOther"
            style="@style/CancelReasonRadio"
            android:text="Other" />

    </RadioGroup>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#1AFFFFFF" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <Button
            android:id="@+id/btnDialogGoBack"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_ghost"
            android:text="Go Back"
            android:textAllCaps="false"
            android:textColor="#F9F1D7"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDialogConfirm"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_confirm"
            android:textColor="#1A1A1A"
            android:text="Confirm"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>