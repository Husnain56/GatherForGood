<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg_gradient"
    tools:context=".CreateEvent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.30"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_star_pattern" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/register_bg_input_field"
            android:padding="8dp"
            android:src="@drawable/register_ic_back_arrow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/soft_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/playfair_display_italic"
            android:text="Create Event"
            android:textColor="#F9F1D7"
            android:textSize="18sp"
            android:textStyle="bold|italic"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ─── Hero Heading ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:paddingTop="8dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/playfair_display_bold"
                    android:text="Organise a&#10;Volunteer Event"
                    android:gravity="center"
                    android:textColor="#F9F1D7"
                    android:textSize="34sp"
                    android:textStyle="bold|italic"
                    android:lineSpacingExtra="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="MAKE A DIFFERENCE IN YOUR COMMUNITY"
                    android:textColor="#66FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.22" />

            </LinearLayout>

            <!-- ─── Form Card ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/home_bg_arch_card"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- ── Event Type ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_event_nofill"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="EVENT TYPE"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field">

                        <Spinner
                            android:id="@+id/spinnerEventType"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:paddingStart="16dp"
                            android:paddingEnd="40dp"
                            android:spinnerMode="dropdown"
                            android:popupBackground="@drawable/register_bg_input_field" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="14dp"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="#D4AF37" />

                    </RelativeLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1AFFFFFF" />

                <!-- ── Event Title ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_description"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="EVENT TITLE"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <EditText
                        android:id="@+id/etEventTitle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:hint="e.g. Ramadan Food Distribution Drive"
                        android:textColorHint="#80F9F1D7"
                        android:inputType="text"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="#F9F1D7"
                        android:textSize="13sp"
                        android:paddingHorizontal="16dp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1AFFFFFF" />

                <!-- ── Volunteers + Gender ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.8"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_person_fill"
                            android:drawablePadding="6dp"
                            android:drawableTint="#D4AF37"
                            android:text="VOLUNTEERS NEEDED"
                            android:textColor="#D4AF37"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.10" />

                        <EditText
                            android:id="@+id/etVolunteersRequired"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/register_bg_input_field"
                            android:hint="e.g. 20"
                            android:textColorHint="#80F9F1D7"
                            android:inputType="number"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="#F9F1D7"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:paddingHorizontal="16dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_person_fill"
                            android:drawablePadding="6dp"
                            android:drawableTint="#D4AF37"
                            android:text="OPEN TO"
                            android:textColor="#D4AF37"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/register_bg_input_field">

                            <Spinner
                                android:id="@+id/spinnerGenderSetting"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:paddingStart="12dp"
                                android:paddingEnd="28dp"
                                android:spinnerMode="dropdown"
                                android:popupBackground="@drawable/register_bg_input_field" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_marginEnd="8dp"
                                android:src="@drawable/ic_arrow_drop_down"
                                app:tint="#D4AF37" />

                        </RelativeLayout>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1AFFFFFF" />

                <!-- ── Start Date ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_calendar"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="START DATE"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <RelativeLayout
                        android:id="@+id/rlDate"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/ivPickDate"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_calendar"
                            android:focusable="false"
                            android:clickable="false"
                            app:tint="#D4AF37" />

                        <TextView
                            android:id="@+id/tvSelectedDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/ivPickDate"
                            android:layout_marginStart="12dp"
                            android:text="Tap to select start date"
                            android:textColor="#80F9F1D7"
                            android:textSize="14sp"
                            android:focusable="false"
                            android:clickable="false" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="#D4AF37" />

                    </RelativeLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1AFFFFFF" />

                <!-- ── Start Time ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_schedule"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="START TIME"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <RelativeLayout
                        android:id="@+id/rlTime"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/ivTimeIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_schedule"
                            android:focusable="false"
                            android:clickable="false"
                            app:tint="#D4AF37" />

                        <TextView
                            android:id="@+id/tvTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/ivTimeIcon"
                            android:layout_marginStart="12dp"
                            android:text="Tap to select start time"
                            android:textColor="#80F9F1D7"
                            android:textSize="14sp"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:focusable="false"
                            android:clickable="false" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="#D4AF37" />

                    </RelativeLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1AFFFFFF" />

                <!-- ── End Date ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_calendar"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="END DATE"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <RelativeLayout
                        android:id="@+id/rlEndDate"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/ivPickEndDate"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_calendar"
                            android:focusable="false"
                            android:clickable="false"
                            app:tint="#D4AF37" />

                        <TextView
                            android:id="@+id/tvSelectedEndDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/ivPickEndDate"
                            android:layout_marginStart="12dp"
                            android:text="Tap to select end date"
                            android:textColor="#80F9F1D7"
                            android:textSize="14sp"
                            android:focusable="false"
                            android:clickable="false" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="#D4AF37" />

                    </RelativeLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1AFFFFFF" />

                <!-- ── End Time ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_schedule"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="END TIME"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <RelativeLayout
                        android:id="@+id/rlEndTime"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/ivEndTimeIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_schedule"
                            android:focusable="false"
                            android:clickable="false"
                            app:tint="#D4AF37" />

                        <TextView
                            android:id="@+id/tvEndTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/ivEndTimeIcon"
                            android:layout_marginStart="12dp"
                            android:text="Tap to select end time"
                            android:textColor="#80F9F1D7"
                            android:textSize="14sp"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:focusable="false"
                            android:clickable="false" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="#D4AF37" />

                    </RelativeLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1AFFFFFF" />

                <!-- ── Location ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_location"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="LOCATION"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFetchLocation"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#1AD4AF37"
                        android:text="Tap to Pin Location"
                        android:textAllCaps="false"
                        android:textColor="#F9F1D7"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:strokeColor="#80D4AF37"
                        app:strokeWidth="1dp"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_location"
                        app:iconTint="#D4AF37"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:iconSize="18dp"
                        app:rippleColor="#22D4AF37" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/home_bg_next_prayer_card"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_location"
                            app:tint="#80E5C76B"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/etLocationDescription"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="No location selected yet"
                            android:textColor="#80F9F1D7"
                            android:textSize="12sp"
                            android:lineSpacingExtra="3dp"
                            android:focusable="false"
                            android:clickable="false" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMapHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text=""
                        android:textColor="#80F9F1D7"
                        android:textSize="11sp"
                        android:gravity="center" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1AFFFFFF" />

                <!-- ── Description ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_description"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="DESCRIPTION"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <EditText
                        android:id="@+id/etDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:gravity="top|start"
                        android:hint="Describe the event, what volunteers will do, what to bring…"
                        android:textColorHint="#80F9F1D7"
                        android:inputType="textMultiLine"
                        android:lines="4"
                        android:maxLines="6"
                        android:minLines="4"
                        android:textColor="#F9F1D7"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1AFFFFFF" />

                <!-- ── Requirements ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:drawableStart="@drawable/ic_verified"
                            android:drawablePadding="6dp"
                            android:drawableTint="#D4AF37"
                            android:text="REQUIREMENTS"
                            android:textColor="#D4AF37"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OPTIONAL"
                            android:textColor="#4DFFFFFF"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                    </LinearLayout>

                    <EditText
                        android:id="@+id/etRequirements"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:gravity="top|start"
                        android:hint="e.g. Bring gloves, wear comfortable shoes…"
                        android:textColorHint="#80F9F1D7"
                        android:inputType="textMultiLine"
                        android:lines="3"
                        android:maxLines="4"
                        android:minLines="3"
                        android:textColor="#F9F1D7"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
