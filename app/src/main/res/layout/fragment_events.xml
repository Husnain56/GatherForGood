<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg_gradient">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.19"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_star_pattern" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <ImageButton
                    android:id="@+id/btnMenu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/register_bg_input_field"
                    android:padding="8dp"
                    android:src="@drawable/ic_menu"
                    app:tint="@color/gold_accent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Volunteer Events"
                    android:textColor="@color/soft_gold"
                    android:textSize="20sp"
                    android:fontFamily="@font/playfair_display_italic"
                    android:textStyle="bold|italic"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/btnMenu" />

                <ImageButton
                    android:id="@+id/btnSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/register_bg_input_field"
                    android:padding="8dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/gold_accent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/register_bg_input_field"
                android:padding="5dp"
                android:weightSum="3">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAllEvents"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/register_bg_gender_active"
                    android:foreground="?attr/selectableItemBackground"
                    android:text="All"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMyEvents"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@android:color/transparent"
                    android:foreground="?attr/selectableItemBackground"
                    android:text="My Events"
                    android:textAllCaps="false"
                    android:textColor="@color/gold_accent"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnJoinedEvents"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:background="@android:color/transparent"
                    android:foreground="?attr/selectableItemBackground"
                    android:text="Joined"
                    android:textAllCaps="false"
                    android:textColor="@color/gold_accent"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutLocationChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp"
                android:weightSum="2">

                <TextView
                    android:id="@+id/chipNearMe"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/prayer_chip_active"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="Near Me"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipSearchCity"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/prayer_chip_inactive"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="Your City"
                    android:textColor="#80E5C76B"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="10dp"
                android:text="UPCOMING EVENTS"
                android:textColor="#80E5C76B"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/prayer_chip_active"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="ALL"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/chipFoodDrive"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/prayer_chip_inactive"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="FOOD DRIVE"
                        android:textColor="#80E5C76B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/chipStreetCleaning"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/prayer_chip_inactive"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="STREET CLEANING"
                        android:textColor="#80E5C76B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/chipClothingDrive"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/prayer_chip_inactive"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="CLOTHING DRIVE"
                        android:textColor="#80E5C76B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/chipBloodDonation"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/prayer_chip_inactive"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="BLOOD DONATION"
                        android:textColor="#80E5C76B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/chipTreePlanting"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/prayer_chip_inactive"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="TREE PLANTING"
                        android:textColor="#80E5C76B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/chipMosqueCleaning"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/prayer_chip_inactive"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="MOSQUE CLEANING"
                        android:textColor="#80E5C76B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/Fundraising"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/prayer_chip_inactive"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="FUNDRAISING"
                        android:textColor="#80E5C76B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                </LinearLayout>

            </HorizontalScrollView>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:indeterminateTint="@color/gold_accent"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="48dp"
                android:paddingBottom="48dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙"
                    android:textSize="48sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No events yet"
                    android:textColor="@color/soft_gold"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/playfair_display_italic"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Be the first to create one!"
                    android:textColor="#80E5C76B"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:paddingBottom="100dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnCreateEvent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Create Event"
        app:backgroundTint="@color/gold_accent"
        app:tint="@color/white"
        app:borderWidth="0dp"
        app:fabSize="normal"
        app:elevation="8dp"
        app:pressedTranslationZ="12dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>