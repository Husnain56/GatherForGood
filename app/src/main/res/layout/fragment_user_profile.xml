<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg_gradient">

    <ImageView
        android:id="@+id/starPattern"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.19"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_star_pattern"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp">>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Profile"
                    android:textColor="@color/soft_gold"
                    android:textSize="20sp"
                    android:fontFamily="@font/playfair_display_italic"
                    android:textStyle="bold|italic"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/btnEdit"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/register_bg_input_field"
                    android:padding="8dp"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/primary"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp">

                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/profile_bg_dashed_ring"
                        android:layout_gravity="center" />

                    <TextView
                        android:id="@+id/tvInitialsAvatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:background="@drawable/register_bg_input_field"
                        android:textColor="@color/soft_gold"
                        android:textSize="36sp"
                        android:fontFamily="@font/playfair_display_italic"
                        android:textStyle="bold|italic" />

                    <View
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        android:background="@drawable/home_bg_online_dot" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:fontFamily="@font/playfair_display_italic"
                    android:textStyle="bold|italic" />

                <LinearLayout
                    android:id="@+id/layoutVerified"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/register_bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VERIFIED"
                        android:textColor="@color/primary"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/home_bg_online_dot"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE MEMBER"
                        android:textColor="#80FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvCity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="City, Country"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/home_bg_next_prayer_card"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_email"
                        app:tint="#80E5C76B"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EMAIL"
                            android:textColor="#80E5C76B"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15" />

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#1AFFFFFF"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_person_fill"
                        app:tint="#80E5C76B"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GENDER"
                            android:textColor="#80E5C76B"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15" />

                        <TextView
                            android:id="@+id/tvGender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingBottom="12dp"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/home_bg_next_prayer_card"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvPrayersJoined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/soft_gold"
                        android:textSize="28sp"
                        android:fontFamily="@font/playfair_display_italic"
                        android:textStyle="bold|italic" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRAYERS\nJOINED"
                        android:textColor="#80FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/home_bg_next_prayer_card"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvPrayersHosted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/soft_gold"
                        android:textSize="28sp"
                        android:fontFamily="@font/playfair_display_italic"
                        android:textStyle="bold|italic" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRAYERS\nHOSTED"
                        android:textColor="#80FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Events Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingBottom="32dp"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/home_bg_next_prayer_card"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvEventsJoined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/soft_gold"
                        android:textSize="28sp"
                        android:fontFamily="@font/playfair_display_italic"
                        android:textStyle="bold|italic" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EVENTS\nJOINED"
                        android:textColor="#80FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/home_bg_next_prayer_card"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvEventsHosted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/soft_gold"
                        android:textSize="28sp"
                        android:fontFamily="@font/playfair_display_italic"
                        android:textStyle="bold|italic" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EVENTS\nHOSTED"
                        android:textColor="#80FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/register_bg_input_field"
                android:text="Sign Out"
                android:textAllCaps="false"
                android:textColor="#CC4444"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDeleteAccount"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/register_bg_input_field"
                android:text="Delete Account"
                android:textAllCaps="false"
                android:textColor="#CC4444"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>