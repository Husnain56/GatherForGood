<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg_gradient"
    tools:context=".CreatePrayer">

    <!-- Star pattern overlay (same as GatheringDetails) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.15"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_star_pattern" />

    <!-- Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/register_bg_input_field"
            android:padding="8dp"
            android:src="@drawable/register_ic_back_arrow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/soft_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/playfair_display_italic"
            android:text="Create Gathering"
            android:textColor="#F9F1D7"
            android:textSize="18sp"
            android:textStyle="bold|italic"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero heading -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:paddingTop="8dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/playfair_display_bold"
                    android:text="Host a Prayer\nGathering"
                    android:gravity="center"
                    android:textColor="#F9F1D7"
                    android:textSize="34sp"
                    android:textStyle="bold|italic"
                    android:lineSpacingExtra="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="CONNECTING HEARTS IN WORSHIP"
                    android:textColor="#66FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.22" />

            </LinearLayout>

            <!-- Form card (arched top like GatheringDetails) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/home_bg_arch_card"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- ── Prayer Type ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_mosque_fill"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="PRAYER TYPE"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <Spinner
                        android:id="@+id/spinnerPrayerType"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:paddingHorizontal="16dp"
                        android:entries="@array/prayer_types"
                        android:spinnerMode="dropdown" />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginVertical="20dp" android:background="#1AFFFFFF" />

                <!-- ── Date ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_calendar"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="DATE"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:id="@+id/tvSelectedDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Select Date"
                            android:textColor="#80F9F1D7"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/btnPickDate"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_calendar"
                            app:tint="#D4AF37" />

                    </RelativeLayout>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginVertical="20dp" android:background="#1AFFFFFF" />

                <!-- ── Time ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_schedule"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="TIME"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <!-- Hour : Minute input -->
                        <EditText
                            android:id="@+id/etTime"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/register_bg_input_field"
                            android:gravity="center"
                            android:hint="07 : 15"
                            android:textColorHint="#80F9F1D7"
                            android:inputType="number"
                            android:maxLength="4"
                            android:textColor="#F9F1D7"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="16dp" />

                        <!-- AM / PM Spinner -->
                        <Spinner
                            android:id="@+id/spinnerAmPm"
                            android:layout_width="88dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/register_bg_input_field"
                            android:entries="@array/am_pm_options"
                            android:spinnerMode="dropdown" />

                    </LinearLayout>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginVertical="20dp" android:background="#1AFFFFFF" />

                <!-- ── Location ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_location"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="LOCATION"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <!-- Location description + GPS button row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etLocationDescription"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/register_bg_input_field"
                            android:hint="e.g. Al-Noor Mosque, Block 7"
                            android:textColorHint="#80F9F1D7"
                            android:inputType="text"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="#F9F1D7"
                            android:textSize="13sp"
                            android:paddingHorizontal="16dp" />

                        <!-- Fetch from Google Maps button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFetchLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="52dp"
                            android:layout_marginStart="10dp"
                            android:backgroundTint="@android:color/transparent"
                            android:text="GPS"
                            android:textAllCaps="false"
                            android:textColor="#D4AF37"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:strokeColor="#4DD4AF37"
                            app:strokeWidth="1.5dp"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/ic_location"
                            app:iconTint="#D4AF37"
                            app:iconGravity="textStart"
                            app:iconPadding="6dp"
                            app:iconSize="16dp"
                            app:rippleColor="#22D4AF37" />

                    </LinearLayout>

                    <!-- Map preview frame -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_details_image_frame"
                        android:clipToOutline="true">

                        <ImageView
                            android:id="@+id/ivMapPreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:alpha="0.45" />

                        <!-- Gradient overlay -->


                        <!-- Center pin -->
                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_circle_emerald">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_location"
                                app:tint="#D4AF37" />

                        </FrameLayout>

                        <!-- Tap hint label -->
                        <TextView
                            android:id="@+id/tvMapHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="10dp"
                            android:text="Tap GPS to pin your location"
                            android:textColor="#80F9F1D7"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                    </FrameLayout>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginVertical="20dp" android:background="#1AFFFFFF" />

                <!-- ── Description ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_description"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="DESCRIPTION"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <EditText
                        android:id="@+id/etDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:gravity="top|start"
                        android:hint="Share the purpose and details of this gathering…"
                        android:textColorHint="#80F9F1D7"
                        android:inputType="textMultiLine"
                        android:lines="4"
                        android:maxLines="6"
                        android:minLines="4"
                        android:textColor="#F9F1D7"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp" />

                </LinearLayout>

                <!-- ── Create Gathering button ── -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCreateGathering"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/register_bg_gender_active"
                    android:text="Create Gathering"
                    android:textAllCaps="false"
                    android:textColor="#042F24"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Bottom spacer -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>