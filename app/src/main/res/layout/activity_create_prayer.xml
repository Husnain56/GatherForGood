<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg_gradient"
    tools:context=".CreatePrayer">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.30"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_star_pattern" />

    <!-- Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/register_bg_input_field"
            android:padding="8dp"
            android:src="@drawable/register_ic_back_arrow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/soft_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/playfair_display_italic"
            android:text="Create Gathering"
            android:textColor="#F9F1D7"
            android:textSize="18sp"
            android:textStyle="bold|italic"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero heading -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="8dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/playfair_display_bold"
                    android:text="Host a Prayer&#10;Gathering"
                    android:gravity="center"
                    android:textColor="#F9F1D7"
                    android:textSize="34sp"
                    android:textStyle="bold|italic"
                    android:lineSpacingExtra="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="CONNECTING HEARTS IN WORSHIP"
                    android:textColor="#66FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.22" />

            </LinearLayout>

            <!-- Form card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/home_bg_arch_card"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- ── Prayer Type ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_mosque_fill"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="PRAYER TYPE"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <!--
                        FIX: Spinner dropdown overlapping the closed label.
                        The first entry in @array/prayer_types must be an empty string ""
                        so the closed view shows the hint text from the adapter set in Java,
                        and the open dropdown shows the real options below it without covering
                        the label above.
                        The Spinner itself is given android:prompt so accessibility still works.
                    -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field">

                        <Spinner
                            android:id="@+id/spinnerPrayerType"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:paddingStart="16dp"
                            android:paddingEnd="40dp"
                            android:spinnerMode="dropdown"
                            android:popupBackground="@drawable/register_bg_input_field" />

                        <!-- Dropdown arrow -->
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="14dp"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="#D4AF37" />

                    </RelativeLayout>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginVertical="20dp" android:background="#1AFFFFFF" />

                <!-- ── Date ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_calendar"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="DATE"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <RelativeLayout
                        android:id="@+id/rldate"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/ivPickDate"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_calendar"
                            app:tint="#D4AF37" />

                        <TextView
                            android:id="@+id/tvSelectedDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/ivPickDate"
                            android:layout_marginStart="12dp"
                            android:text="Tap to select date"
                            android:textColor="#80F9F1D7"
                            android:textSize="14sp"
                            android:focusable="false"
                            android:clickable="false" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="#D4AF37" />

                    </RelativeLayout>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginVertical="20dp" android:background="#1AFFFFFF" />

                <!-- ── Time ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_schedule"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="TIME"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <!-- Single full-width row. AM/PM is included in tvTime text ("07:00 AM").
                         No separate spinner — eliminates the overflow/overlap entirely. -->
                    <RelativeLayout
                        android:id="@+id/rlTime"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/ivTimeIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_schedule"
                            app:tint="#D4AF37" />

                        <TextView
                            android:id="@+id/tvTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/ivTimeIcon"
                            android:layout_alignParentEnd="true"
                            android:layout_marginStart="12dp"
                            android:text="Tap to select time"
                            android:textColor="#80F9F1D7"
                            android:textSize="14sp"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:focusable="false"
                            android:clickable="false" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="#D4AF37" />

                    </RelativeLayout>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginVertical="20dp" android:background="#1AFFFFFF" />

                <!-- ── Location ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_location"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="LOCATION"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFetchLocation"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#1AD4AF37"
                        android:text="Tap to Pin Location"
                        android:textAllCaps="false"
                        android:textColor="#F9F1D7"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:strokeColor="#80D4AF37"
                        app:strokeWidth="1dp"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_location"
                        app:iconTint="#D4AF37"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:iconSize="18dp"
                        app:rippleColor="#22D4AF37" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/home_bg_next_prayer_card"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_location"
                            app:tint="#80E5C76B"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/etLocationDescription"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="No location selected yet"
                            android:textColor="#80F9F1D7"
                            android:textSize="12sp"
                            android:lineSpacingExtra="3dp"
                            android:focusable="false"
                            android:clickable="false" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMapHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text=""
                        android:textColor="#80F9F1D7"
                        android:textSize="11sp"
                        android:gravity="center" />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginVertical="20dp" android:background="#1AFFFFFF" />

                <!-- ── Description ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_description"
                        android:drawablePadding="6dp"
                        android:drawableTint="#D4AF37"
                        android:text="DESCRIPTION"
                        android:textColor="#D4AF37"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <EditText
                        android:id="@+id/etDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/register_bg_input_field"
                        android:gravity="top|start"
                        android:hint="Share the purpose and details of this gathering…"
                        android:textColorHint="#80F9F1D7"
                        android:inputType="textMultiLine"
                        android:lines="4"
                        android:maxLines="6"
                        android:minLines="4"
                        android:textColor="#F9F1D7"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp" />

                </LinearLayout>

                <!-- ── Create button ── -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCreateGathering"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/register_bg_gender_active"
                    android:text="Create Gathering"
                    android:textAllCaps="false"
                    android:textColor="#042F24"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <View android:layout_width="match_parent" android:layout_height="24dp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>