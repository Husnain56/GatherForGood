<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg_gradient"
    tools:context=".GatheringDetails">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.15"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_star_pattern" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/register_bg_input_field"
            android:padding="8dp"
            android:src="@drawable/register_ic_back_arrow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/soft_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/playfair_display_italic"
            android:text="Gathering Details"
            android:textColor="#F9F1D7"
            android:textSize="18sp"
            android:textStyle="bold|italic"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/home_bg_arch_card"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Status badge -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.2"
                android:textColor="#D4AF37"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/playfair_display_bold"
                android:textColor="#F9F1D7"
                android:textSize="28sp" />

            <!-- ─── Location Box ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="LOCATION"
                android:textColor="#80E5C76B"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/home_bg_next_prayer_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:id="@+id/llLocation"
                android:padding="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_location"
                    app:tint="#80E5C76B"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvLocationDescription"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#CCF9F1D7"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"
                    tools:text="Grand Mosque, Lahore" />

            </LinearLayout>

            <!-- ─── About Section ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="ABOUT THIS GATHERING"
                android:textColor="#80E5C76B"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:alpha="0.8"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- ─── Divider ─── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="#1AFFFFFF" />

            <!-- Prayer Time row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="16dp">

                <ImageView
                    android:id="@+id/iconTime"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_schedule"
                    android:background="@drawable/bg_circle_emerald"
                    android:padding="10dp"
                    app:tint="#D4AF37" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/iconTime"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRAYER TIME"
                        android:textSize="9sp"
                        android:textColor="#80FFFFFF"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvPrayerTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F9F1D7"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvPrayerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/prayer_bg_time_badge"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textColor="#0FBD66"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <!-- ─── Divider ─── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF" />

            <!-- Host row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="16dp">

                <ImageView
                    android:id="@+id/iconHost"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_person_fill"
                    android:background="@drawable/bg_circle_emerald"
                    android:padding="10dp"
                    app:tint="#D4AF37" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/iconHost"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOST"
                        android:textSize="9sp"
                        android:textColor="#80FFFFFF"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvHostName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F9F1D7"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PARTICIPANTS"
                        android:textSize="9sp"
                        android:textColor="#80FFFFFF"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAttendingCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F9F1D7"
                        android:textStyle="bold" />

                </LinearLayout>

            </RelativeLayout>

            <!-- ─── Divider ─── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF" />

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:indeterminateTint="@color/gold_accent"
                android:visibility="gone" />

            <!-- Join Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnJoin"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/register_bg_gender_active"
                android:text="Join Gathering"
                android:textAllCaps="false"
                android:textColor="#042F24"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Open in Maps Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenMaps"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#1AD4AF37"
                android:text="Open in Maps"
                android:textAllCaps="false"
                android:textColor="#F9F1D7"
                android:textSize="16sp"
                android:textStyle="bold"
                app:strokeColor="#80D4AF37"
                app:strokeWidth="1dp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_map"
                app:iconTint="#D4AF37"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:rippleColor="#22D4AF37" />

            <!-- ─── Chat Section ─── -->
            <LinearLayout
                android:id="@+id/layoutChatButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="40dp"
                android:background="@drawable/home_bg_next_prayer_card"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="CHAT"
                    android:textColor="#80E5C76B"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGroupChat"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="#1AD4AF37"
                    android:text="Group Chat"
                    android:textAllCaps="false"
                    android:textColor="#F9F1D7"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:strokeColor="#4DB89548"
                    app:strokeWidth="1dp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_chat"
                    app:iconTint="#D4AF37"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:rippleColor="#22B89548" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>