<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="4dp"
    android:background="@drawable/prayer_bg_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:clipToOutline="true"
    android:minHeight="160dp">

    <!-- ── Top Banner (taller, more presence) ── -->
    <View
        android:id="@+id/cardTopBanner"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/prayer_bg_card_banner"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Status label centered in banner -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UPCOMING GATHERING"
        android:textColor="@color/gold_accent"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.3"
        app:layout_constraintTop_toTopOf="@id/cardTopBanner"
        app:layout_constraintBottom_toBottomOf="@id/cardTopBanner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Prayer Name (larger) ── -->
    <TextView
        android:id="@+id/tvPrayerName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="12dp"
        android:text="Fajr Congregation"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardTopBanner"
        app:layout_constraintEnd_toStartOf="@id/tvTime" />

    <!-- ── Time Badge (right-aligned) ── -->
    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:background="@drawable/prayer_bg_time_badge"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:text="5:15 AM"
        android:textColor="@color/primary"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBaseline_toBaselineOf="@id/tvPrayerName" />

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        android:text="Join us for the morning congregation. All are welcome."
        android:textColor="#66FFFFFF"
        android:textSize="12sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPrayerName"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Host Name ── -->
    <LinearLayout
        android:id="@+id/hostContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDescription">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_person_fill"
            android:layout_marginEnd="6dp"
            app:tint="@color/primary" />

        <TextView
            android:id="@+id/tvHostName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hosted by Ahmed Khan"
            android:textColor="@color/primary"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- ── Location Row ── -->
    <LinearLayout
        android:id="@+id/locationContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hostContainer"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_location"
            android:layout_marginEnd="6dp"
            app:tint="#80D4AF37" />

        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Community Center Hall A"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- ── Divider ── -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        android:background="#1AB89548"
        app:layout_constraintTop_toBottomOf="@id/locationContainer" />

    <!-- ── Bottom Row: participant count + JOIN button ── -->
    <LinearLayout
        android:id="@+id/bottomRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Participant count with icon -->
        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_person_fill"
            android:layout_marginEnd="6dp"
            app:tint="#66FFFFFF" />

        <TextView
            android:id="@+id/tvParticipantCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="12 joined"
            android:textColor="#80FFFFFF"
            android:textSize="12sp" />

        <!-- JOIN button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnJoin"
            android:layout_width="90dp"
            android:layout_height="38dp"
            android:background="@drawable/prayer_chip_active"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="VIEW"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:stateListAnimator="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>