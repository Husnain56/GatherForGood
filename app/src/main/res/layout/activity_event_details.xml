<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg_gradient">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.15"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_star_pattern" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/register_bg_input_field"
            android:padding="8dp"
            android:src="@drawable/register_ic_back_arrow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/soft_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/playfair_display_italic"
            android:text="Event Details"
            android:textColor="#F9F1D7"
            android:textSize="18sp"
            android:textStyle="bold|italic"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/home_bg_arch_card"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ─── Type + Status badges ─── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvEventType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/prayer_chip_inactive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textColor="#80E5C76B"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    tools:text="FOOD DRIVE" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/register_bg_gender_active"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    tools:text="UPCOMING" />

            </LinearLayout>

            <!-- ─── Title ─── -->
            <TextView
                android:id="@+id/tvEventTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/playfair_display_bold"
                android:textColor="#F9F1D7"
                android:textSize="26sp"
                android:lineSpacingExtra="4dp"
                tools:text="Ramadan Food Distribution Drive" />

            <!-- ─── Organizer ─── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="By "
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvOrganizerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gold_accent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="Husnain Barkat Ali" />

            </LinearLayout>

            <!-- ─── Location Box ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="LOCATION"
                android:textColor="#80E5C76B"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <LinearLayout
                android:id="@+id/llLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/home_bg_next_prayer_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_location"
                    app:tint="#80E5C76B"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvEventLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#CCF9F1D7"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"
                    tools:text="Grand Islamic Center, Lahore" />

            </LinearLayout>

            <!-- ─── Date/Time Card (start → end) + Slots Card ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="DATE &amp; TIME"
                android:textColor="#80E5C76B"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <!-- Date card showing FROM / TO rows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/home_bg_next_prayer_card"
                android:orientation="vertical"
                android:padding="14dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_event_nofill"
                    app:tint="#80E5C76B"
                    android:layout_marginBottom="10dp" />

                <!-- FROM row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="FROM"
                        android:textColor="#66FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvEventDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:textColor="#F9F1D7"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="Sat, 19 Apr 2026" />

                    <TextView
                        android:id="@+id/tvEventTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/gold_accent"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"
                        tools:text="09:00 AM" />

                </LinearLayout>

                <!-- Thin divider between rows -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginVertical="10dp"
                    android:background="#1AFFFFFF" />

                <!-- TO row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="TO"
                        android:textColor="#66FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvEventEndDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:textColor="#F9F1D7"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="Sat, 19 Apr 2026" />

                    <TextView
                        android:id="@+id/tvEventEndTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/gold_accent"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"
                        tools:text="05:00 PM" />

                </LinearLayout>

            </LinearLayout>

            <!-- Slots card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/home_bg_next_prayer_card"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_person_fill"
                    app:tint="#80E5C76B"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SLOTS"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvSlots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/soft_gold"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/playfair_display_italic"
                    android:layout_marginTop="4dp"
                    tools:text="18/20" />

            </LinearLayout>

            <!-- ─── About Section ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="ABOUT THIS EVENT"
                android:textColor="#80E5C76B"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:alpha="0.8"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:maxLines="4"
                android:ellipsize="end"
                tools:text="Join us for our annual Ramadan food distribution drive." />

            <TextView
                android:id="@+id/tvReadMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Read more"
                android:textColor="@color/gold_accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- ─── Requirements Section ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="REQUIREMENTS"
                android:textColor="#80E5C76B"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/home_bg_next_prayer_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_person_fill"
                        app:tint="#80E5C76B"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FOR"
                        android:textColor="#80FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvRequirementGender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F9F1D7"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="Brothers Only" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginVertical="10dp"
                    android:background="#1AFFFFFF" />

                <TextView
                    android:id="@+id/tvRequirements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.8"
                    android:lineSpacingExtra="6dp"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:text="No Requirements" />

            </LinearLayout>

            <!-- ─── Divider ─── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="24dp"
                android:background="#1AFFFFFF" />

            <!-- ─── Organizer Detail Row ─── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="16dp">

                <ImageView
                    android:id="@+id/iconOrganizer"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_person_fill"
                    android:background="@drawable/bg_circle_emerald"
                    android:padding="10dp"
                    app:tint="#D4AF37" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/iconOrganizer"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ORGANIZER"
                        android:textSize="9sp"
                        android:textColor="#80FFFFFF"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvOrganizerNameDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F9F1D7"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginTop="2dp"
                        tools:text="Husnain Barkat Ali" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PARTICIPANTS"
                        android:textSize="9sp"
                        android:textColor="#80FFFFFF"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvParticipantCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F9F1D7"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginTop="2dp"
                        tools:text="18 Attending" />

                </LinearLayout>

            </RelativeLayout>

            <!-- ─── Divider ─── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#1AFFFFFF" />

            <!-- ─── Progress Bar ─── -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:indeterminateTint="@color/gold_accent"
                android:visibility="gone" />

            <!-- ─── Join Button ─── -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnJoin"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/register_bg_gender_active"
                android:text="Join"
                android:textAllCaps="false"
                android:textColor="#042F24"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- ─── Open in Maps Button ─── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenMaps"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#1AD4AF37"
                android:text="Open in Maps"
                android:textAllCaps="false"
                android:textColor="#F9F1D7"
                android:textSize="16sp"
                android:textStyle="bold"
                app:strokeColor="#80D4AF37"
                app:strokeWidth="1dp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_map"
                app:iconTint="#D4AF37"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:rippleColor="#22D4AF37" />

            <!-- ─── Chat Section ─── -->
            <LinearLayout
                android:id="@+id/layoutChatButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="40dp"
                android:background="@drawable/home_bg_next_prayer_card"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="CHAT"
                    android:textColor="#80E5C76B"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGroupChat"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="#1AD4AF37"
                    android:text="Group Chat"
                    android:textAllCaps="false"
                    android:textColor="#F9F1D7"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:strokeColor="#4DB89548"
                    app:strokeWidth="1dp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_chat"
                    app:iconTint="#D4AF37"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:rippleColor="#22B89548" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMessageHost"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="#1AD4AF37"
                    android:text="Message Host"
                    android:textAllCaps="false"
                    android:textColor="#F9F1D7"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:strokeColor="#4DB89548"
                    app:strokeWidth="1dp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_person_fill"
                    app:iconTint="#D4AF37"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:rippleColor="#22B89548" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>