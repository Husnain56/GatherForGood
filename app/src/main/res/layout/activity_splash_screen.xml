<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <!-- Star Pattern Background -->
    <ImageView
        android:id="@+id/starPattern"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.04"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_star_pattern"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Artistic Overlay -->
    <View
        android:id="@+id/topOverlay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/overlay_top"
        app:layout_constraintHeight_percent="0.33"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Bottom Artistic Overlay -->
    <View
        android:id="@+id/bottomOverlay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:alpha="0.9"
        android:background="@drawable/overlay_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.5" />

    <!-- Main Content Group (Centered with bias) -->
    <LinearLayout
        android:id="@+id/contentGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/bottomSection"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <!-- Line-Art Mosque -->
        <ImageView
            android:id="@+id/mosqueIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_mosque_line" />

        <!-- App Name -->
        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/playfair_display_italic"
            android:text="@string/app_name"
            android:textColor="#E5C76B"
            android:textSize="48sp"
            android:textStyle="italic" />

        <!-- Elegant Gradient Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="128dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/divider_gradient" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:letterSpacing="0.25"
            android:text="@string/app_tagline"
            android:textAllCaps="true"
            android:textColor="#99FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Bottom Section -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="80dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Community Synergy + Status Dot -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/statusDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/circle_gold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.3"
                android:text="@string/splash_desc"
                android:textColor="#99D4AF37"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true" />
        </LinearLayout>

        <!-- Modern Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="200dp"
            android:layout_height="2dp"
            android:progress="45"
            android:progressBackgroundTint="#1AFFFFFF"
            android:progressTint="#D4AF37" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>